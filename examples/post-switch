#!/bin/sh
# Example post-switch hook for uso
# Copy to ~/.config/uso/post-switch and chmod +x
#
# Receives the profile name as $1

profile="$1"

# iTerm2 tab colors
iterm_color() {
  printf "\033]6;1;bg;red;brightness;%d\a"   "$1"
  printf "\033]6;1;bg;green;brightness;%d\a" "$2"
  printf "\033]6;1;bg;blue;brightness;%d\a"  "$3"
}

case "$profile" in
  home)     iterm_color 51  51  51  ;;  # dark gray
  work)     iterm_color 0   168 120 ;;  # teal
  personal) iterm_color 139 92  246 ;;  # purple
esac

# Terminal title
printf "\033]0;%s\a" "$profile"
